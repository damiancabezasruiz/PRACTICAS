<?php
/**
 * API PÚBLICA — opciones ocultas por form_id
 * Sin autenticación, solo lectura.
 */
require_once __DIR__ . '/db.php';

header('Content-Type: application/json; charset=utf-8');
// Permitir llamadas desde el mismo dominio
header('Access-Control-Allow-Origin: *');

$tipo = $_GET['tipo'] ?? 'incidencias';
$form_id = ($tipo === 'valoraciones') ? 16 : 18;

$sql = "SELECT i.value as opcion_nombre, f.label as pregunta_nombre
        FROM custom_hidden_fields h
        INNER JOIN ost_list_items i ON i.id = h.field_id
        INNER JOIN ost_form_field f ON f.type = CONCAT('list-', i.list_id)
        WHERE h.form_id = $form_id
        AND h.hidden = 1
        AND f.form_id = $form_id";

$res = $mysqli->query($sql);
$items = [];
if ($res) while ($row = $res->fetch_assoc()) { $items[] = $row; }

echo json_encode(['ok' => true, 'items' => $items]);